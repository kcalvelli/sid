From 17aa401b9febcdfbbf8e207df7d89081078f95ed Mon Sep 17 00:00:00 2001
From: Keith Calvelli <keith@calvelli.dev>
Date: Mon, 16 Mar 2026 15:18:38 -0400
Subject: [PATCH 10/10] feat: add channel context prefix to Telegram messages

---
 src/channels/telegram.rs | 12 ++++++++++++
 1 file changed, 12 insertions(+)

diff --git a/src/channels/telegram.rs b/src/channels/telegram.rs
index 972a090..f07b657 100644
--- a/src/channels/telegram.rs
+++ b/src/channels/telegram.rs
@@ -1,4 +1,10 @@
 use super::traits::{Channel, ChannelMessage, SendMessage};
+
+/// Context prefix prepended to every Telegram message before it reaches the LLM.
+const TELEGRAM_STYLE_PREFIX: &str = "\
+[context: you are responding via Telegram. \
+Keep responses concise. Telegram supports markdown formatting.]\n";
+
 use crate::config::{Config, StreamMode};
 use crate::security::pairing::PairingGuard;
 use anyhow::Context;
@@ -2710,6 +2716,12 @@ Ensure only one `zeroclaw` process is using this bot token."
                         .send()
                         .await; // Ignore errors for typing indicator

+                    // Inject channel context so the LLM knows the source
+                    // Skip for slash commands so runtime command parsing still works
+                    let mut msg = msg;
+                    if !msg.content.trim().starts_with('/') {
+                        msg.content = format!("{TELEGRAM_STYLE_PREFIX}{}", msg.content);
+                    }
                     if tx.send(msg).await.is_err() {
                         return Ok(());
                     }
