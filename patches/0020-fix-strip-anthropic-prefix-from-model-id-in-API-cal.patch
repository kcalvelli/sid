From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Keith Calvelli <keith@calvelli.dev>
Date: Thu, 27 Mar 2026 00:00:00 -0400
Subject: [PATCH 20/20] fix: strip anthropic/ prefix from model ID in API calls

Model IDs stored with the OpenRouter `provider/model` convention
(e.g. `anthropic/claude-sonnet-4-6`) cause a 404 when sent to the
Anthropic API, which expects bare model IDs.  Strip the `anthropic/`
prefix in all Anthropic provider methods before building the request.
---
 src/providers/anthropic.rs | 15 ++++++++++++---
 1 file changed, 12 insertions(+), 3 deletions(-)

diff --git a/src/providers/anthropic.rs b/src/providers/anthropic.rs
index 1e17c14..5cea047 100644
--- a/src/providers/anthropic.rs
+++ b/src/providers/anthropic.rs
@@ -198,6 +198,15 @@ impl AnthropicProvider {
         }
     }

+    /// Strip OpenRouter-style provider prefix (e.g. `anthropic/claude-sonnet-4-6`
+    /// → `claude-sonnet-4-6`).  The Anthropic API expects bare model IDs; callers
+    /// that store the OpenRouter `provider/model` convention would otherwise 404.
+    fn strip_model_prefix(model: &str) -> &str {
+        model
+            .strip_prefix("anthropic/")
+            .unwrap_or(model)
+    }
+
     /// Override the maximum output tokens for API requests.
     pub fn with_max_tokens(mut self, max_tokens: u32) -> Self {
         self.max_tokens = max_tokens;
@@ -729,7 +738,7 @@ impl Provider for AnthropicProvider {
         };

         let request = NativeChatRequest {
-            model: model.to_string(),
+            model: Self::strip_model_prefix(model).to_string(),
             max_tokens: self.max_tokens,
             system,
             messages: vec![NativeMessage {
@@ -806,7 +815,7 @@ impl Provider for AnthropicProvider {
             system_prompt
         };
         let native_request = NativeChatRequest {
-            model: model.to_string(),
+            model: Self::strip_model_prefix(model).to_string(),
             max_tokens: self.max_tokens,
             system: system_prompt,
             messages,
@@ -959,7 +968,7 @@ impl Provider for AnthropicProvider {
         };

         let native_request = NativeChatRequest {
-            model: model.to_string(),
+            model: Self::strip_model_prefix(model).to_string(),
             max_tokens: 4096,
             system: system_prompt,
             messages,
--
