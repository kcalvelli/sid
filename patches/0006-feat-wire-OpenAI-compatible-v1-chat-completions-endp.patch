From 112547150d67e660a2974b584ca10c960e143f5d Mon Sep 17 00:00:00 2001
From: Keith Calvelli <keith@calvelli.dev>
Date: Fri, 13 Mar 2026 09:55:11 -0400
Subject: [PATCH 06/10] feat: wire OpenAI-compatible /v1/chat/completions
 endpoint

Add openai_proxy module declaration and route the /v1/chat/completions
endpoint through a sub-router with 1MB body limit. The actual proxy
implementation (openai_proxy.rs) is provided separately as a new file.
---
 src/gateway/mod.rs | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/src/gateway/mod.rs b/src/gateway/mod.rs
index 5fec65d..dcbf70d 100644
--- a/src/gateway/mod.rs
+++ b/src/gateway/mod.rs
@@ -11,6 +11,7 @@ pub mod api;
 pub mod sse;
 pub mod static_files;
 pub mod ws;
+pub mod openai_proxy;
 
 use chrono::Local;
 use crate::channels::{
@@ -654,6 +655,10 @@ pub async fn run_gateway(host: &str, port: u16, config: Config) -> Result<()> {
         shutdown_tx,
     };
 
+    let chat_completions_router = Router::new()
+        .route("/v1/chat/completions", post(openai_proxy::handle_chat_completions))
+        .layer(RequestBodyLimitLayer::new(1_048_576));
+
     // Config PUT needs larger body limit (1MB)
     let config_put_router = Router::new()
         .route("/api/config", put(api::handle_api_config_put))
@@ -707,6 +712,7 @@ pub async fn run_gateway(host: &str, port: u16, config: Config) -> Result<()> {
         .route("/_app/{*path}", get(static_files::handle_static))
         // ── Config PUT with larger body limit ──
         .merge(config_put_router)
+        .merge(chat_completions_router)
         .with_state(state)
         .layer(RequestBodyLimitLayer::new(MAX_BODY_SIZE))
         .layer(TimeoutLayer::with_status_code(
