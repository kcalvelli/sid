@@ -71,6 +92,14 @@
         prompt: &str,
         timeout_secs: u64,
     ) -> Result<String, String> {
+        // Agentic path: full agent loop with ZeroClaw tools.
+        if agent_config.agentic {
+            return self
+                .call_agent_agentic(agent_name, agent_config, prompt, timeout_secs)
+                .await;
+        }
+
+        // Non-agentic path: single LLM call.
         let provider = self
             .create_provider_for_agent(agent_config, agent_name)
             .map_err(|r| r.error.unwrap_or_default())?;
@@ -103,6 +132,57 @@
         }
     }

+    /// Run an agentic worker through the full ZeroClaw agent loop, giving it
+    /// access to all configured tools (shell, memory, web_fetch, etc.).
+    async fn call_agent_agentic(
+        &self,
+        agent_name: &str,
+        agent_config: &DelegateAgentConfig,
+        prompt: &str,
+        timeout_secs: u64,
+    ) -> Result<String, String> {
+        let base_config = match &self.config {
+            Some(c) => c.clone(),
+            None => {
+                return Err(format!(
+                    "Agent '{agent_name}' is agentic but SwarmTool was created without config"
+                ));
+            }
+        };
+
+        // Build a worker config with the agent's provider/model.
+        let mut worker_config = base_config;
+        worker_config.default_provider = Some(agent_config.provider.clone());
+        worker_config.default_model = Some(agent_config.model.clone());
+        if let Some(ref key) = agent_config.api_key {
+            worker_config.api_key = Some(key.clone());
+        } else if worker_config.api_key.is_none() {
+            if let Some(ref fallback) = self.fallback_credential {
+                worker_config.api_key = Some(fallback.clone());
+            }
+        }
+
+        // Prepend the agent's system prompt as context.
+        let full_prompt = if let Some(ref sys) = agent_config.system_prompt {
+            format!("[System instructions]\n{sys}\n\n[Task]\n{prompt}")
+        } else {
+            prompt.to_string()
+        };
+
+        let result = tokio::time::timeout(
+            Duration::from_secs(timeout_secs),
+            crate::agent::process_message(worker_config, &full_prompt, None),
+        )
+        .await;
+
+        match result {
+            Ok(Ok(response)) if response.trim().is_empty() => Ok("[Empty response]".to_string()),
+            Ok(Ok(response)) => Ok(response),
+            Ok(Err(e)) => Err(format!("Agent '{agent_name}' agentic loop failed: {e}")),
+            Err(_) => Err(format!("Agent '{agent_name}' timed out after {timeout_secs}s")),
+        }
+    }
+
     async fn execute_sequential(
         &self,
         swarm_config: &SwarmConfig,
