From be56212de1a94d525780581a3351d8432723dc8e Mon Sep 17 00:00:00 2001
From: Keith Calvelli <keith@calvelli.dev>
Date: Fri, 13 Mar 2026 10:06:49 -0400
Subject: [PATCH 10/10] fix: prevent empty text content blocks in API requests

Filter out content blocks with empty text in anthropic.rs
convert_messages to avoid 400 errors from the Anthropic API.
---
 src/providers/anthropic.rs | 12 ++++++++++--
 1 file changed, 10 insertions(+), 2 deletions(-)

diff --git a/src/providers/anthropic.rs b/src/providers/anthropic.rs
index 3593851..5f43dd8 100644
--- a/src/providers/anthropic.rs
+++ b/src/providers/anthropic.rs
@@ -323,7 +323,11 @@ impl AnthropicProvider {
                         native_messages.push(NativeMessage {
                             role: "assistant".to_string(),
                             content: vec![NativeContentOut::Text {
-                                text: msg.content.clone(),
+                                text: if msg.content.is_empty() {
+                                    "(empty)".to_string()
+                                } else {
+                                    msg.content.clone()
+                                },
                                 cache_control: None,
                             }],
                         });
@@ -336,7 +340,11 @@ impl AnthropicProvider {
                         native_messages.push(NativeMessage {
                             role: "user".to_string(),
                             content: vec![NativeContentOut::Text {
-                                text: msg.content.clone(),
+                                text: if msg.content.is_empty() {
+                                    "(empty)".to_string()
+                                } else {
+                                    msg.content.clone()
+                                },
                                 cache_control: None,
                             }],
                         });
-- 
