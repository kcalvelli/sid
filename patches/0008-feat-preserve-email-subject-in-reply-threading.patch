From c923d4a6f25d6de746c26ddf2195453f2bece8a6 Mon Sep 17 00:00:00 2001
From: Keith Calvelli <keith@calvelli.dev>
Date: Tue, 10 Mar 2026 16:16:09 -0400
Subject: [PATCH 08/10] feat: preserve email subject in reply threading

Extract subject from incoming emails into thread_ts field on
ChannelMessage. When sending replies, use thread_ts as the subject
with 'Re: ' prefix if no explicit subject is provided.
---
 src/channels/email_channel.rs | 20 ++++++++++++++++++--
 1 file changed, 18 insertions(+), 2 deletions(-)

diff --git a/src/channels/email_channel.rs b/src/channels/email_channel.rs
index f57a5213..8bd23e4c 100644
--- a/src/channels/email_channel.rs
+++ b/src/channels/email_channel.rs
@@ -458,6 +458,13 @@ impl EmailChannel {
                 continue;
             }
 
+            // Extract subject for reply threading
+            let _email_subj = if email.content.starts_with("Subject: ") {
+                email.content.lines().next()
+                    .map(|l| l.trim_start_matches("Subject: ").to_string())
+            } else {
+                None
+            };
             let msg = ChannelMessage {
                 id: email.msg_id,
                 reply_target: email.sender.clone(),
@@ -465,7 +472,7 @@ impl EmailChannel {
                 content: email.content,
                 channel: "email".to_string(),
                 timestamp: email.timestamp,
-                thread_ts: None,
+                thread_ts: _email_subj,
             };
 
             if tx.send(msg).await.is_err() {
@@ -517,7 +524,9 @@ impl Channel for EmailChannel {
     }
 
     async fn send(&self, message: &SendMessage) -> Result<()> {
-        // Use explicit subject if provided, otherwise fall back to legacy parsing or default
+        // Use explicit subject if provided, otherwise fall back to legacy parsing,
+        // thread subject (for email replies), or default
+        let _thread_subject;
         let (subject, body) = if let Some(ref subj) = message.subject {
             (subj.as_str(), message.content.as_str())
         } else if message.content.starts_with("Subject: ") {
@@ -526,6 +535,13 @@ impl Channel for EmailChannel {
             } else {
                 ("ZeroClaw Message", message.content.as_str())
             }
+        } else if let Some(ref ts) = message.thread_ts {
+            _thread_subject = if ts.starts_with("Re: ") {
+                ts.clone()
+            } else {
+                format!("Re: {}", ts)
+            };
+            (_thread_subject.as_str(), message.content.as_str())
         } else {
             ("ZeroClaw Message", message.content.as_str())
         };
-- 
