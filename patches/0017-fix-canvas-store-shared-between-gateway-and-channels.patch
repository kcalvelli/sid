From 96dc5674ec6b02bee91a0fa5c1cb8ae27fe0836f Mon Sep 17 00:00:00 2001
From: Keith Calvelli <keith@calvelli.dev>
Date: Wed, 25 Mar 2026 12:33:44 -0400
Subject: [PATCH] fix: share CanvasStore between gateway and channels

The daemon spawns the gateway and channels independently, each creating
their own CanvasStore. When an agent pushes to canvas via a channel
(Telegram, dashboard chat), the frame is stored in the channel's orphan
store, not the gateway's store that WebSocket subscribers watch.

Fix: create a single CanvasStore in the daemon and thread it through to
both run_gateway and start_channels so they share the same broadcast.
---
 src/channels/mod.rs |  4 ++--
 src/daemon/mod.rs   | 10 ++++++++--
 src/gateway/mod.rs  |  4 ++--
 src/main.rs         | 10 +++++-----
 4 files changed, 17 insertions(+), 11 deletions(-)

diff --git a/src/channels/mod.rs b/src/channels/mod.rs
index 953dcd4..45b0597 100644
--- a/src/channels/mod.rs
+++ b/src/channels/mod.rs
@@ -4557,7 +4557,7 @@ pub async fn doctor_channels(config: Config) -> Result<()> {
 
 /// Start all configured channels and route messages to the agent
 #[allow(clippy::too_many_lines)]
-pub async fn start_channels(config: Config) -> Result<()> {
+pub async fn start_channels(config: Config, canvas_store: Option<crate::tools::CanvasStore>) -> Result<()> {
     let provider_name = resolved_default_provider(&config);
     let provider_runtime_options = providers::ProviderRuntimeOptions {
         auth_profile_override: None,
@@ -4648,7 +4648,7 @@ pub async fn start_channels(config: Config) -> Result<()> {
         &config.agents,
         config.api_key.as_deref(),
         &config,
-        None,
+        canvas_store,
     );
 
     // Wire MCP tools into the registry before freezing — non-fatal.
diff --git a/src/daemon/mod.rs b/src/daemon/mod.rs
index 036e81b..c52d2c3 100644
--- a/src/daemon/mod.rs
+++ b/src/daemon/mod.rs
@@ -62,9 +62,12 @@ pub async fn run(config: Config, host: String, port: u16) -> Result<()> {
 
     let mut handles: Vec<JoinHandle<()>> = vec![spawn_state_writer(config.clone())];
 
+    let canvas_store = crate::tools::CanvasStore::new();
+
     {
         let gateway_cfg = config.clone();
         let gateway_host = host.clone();
+        let gw_canvas = canvas_store.clone();
         handles.push(spawn_component_supervisor(
             "gateway",
             initial_backoff,
@@ -72,7 +75,8 @@ pub async fn run(config: Config, host: String, port: u16) -> Result<()> {
             move || {
                 let cfg = gateway_cfg.clone();
                 let host = gateway_host.clone();
-                async move { Box::pin(crate::gateway::run_gateway(&host, port, cfg)).await }
+                let cs = gw_canvas.clone();
+                async move { Box::pin(crate::gateway::run_gateway(&host, port, cfg, Some(cs))).await }
             },
         ));
     }
@@ -80,13 +84,15 @@ pub async fn run(config: Config, host: String, port: u16) -> Result<()> {
     {
         if has_supervised_channels(&config) {
             let channels_cfg = config.clone();
+            let ch_canvas = canvas_store.clone();
             handles.push(spawn_component_supervisor(
                 "channels",
                 initial_backoff,
                 max_backoff,
                 move || {
                     let cfg = channels_cfg.clone();
-                    async move { Box::pin(crate::channels::start_channels(cfg)).await }
+                    let cs = ch_canvas.clone();
+                    async move { Box::pin(crate::channels::start_channels(cfg, Some(cs))).await }
                 },
             ));
         } else {
diff --git a/src/gateway/mod.rs b/src/gateway/mod.rs
index aa43e36..ef27b47 100644
--- a/src/gateway/mod.rs
+++ b/src/gateway/mod.rs
@@ -366,7 +366,7 @@ pub struct AppState {
 
