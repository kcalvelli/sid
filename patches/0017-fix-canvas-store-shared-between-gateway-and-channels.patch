     // ── Security: refuse public bind without tunnel or explicit opt-in ──
     if is_public_bind(host) && config.tunnel.provider == "none" && !config.gateway.allow_public_bind
     {
@@ -438,7 +438,7 @@ pub async fn run_gateway(host: &str, port: u16, config: Config) -> Result<()> {
         (None, None)
     };
 
-    let canvas_store = tools::CanvasStore::new();
+    let canvas_store = canvas_store.unwrap_or_else(tools::CanvasStore::new);
 
     let (
         mut tools_registry_raw,
diff --git a/src/main.rs b/src/main.rs
index a95f712..cb74796 100644
--- a/src/main.rs
+++ b/src/main.rs
@@ -935,7 +935,7 @@ async fn main() -> Result<()> {
 
         // Auto-start channels if user said yes during wizard
