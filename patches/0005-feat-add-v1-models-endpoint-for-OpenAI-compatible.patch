From: Keith Calvelli <keith@calvelli.dev>
Date: Mon, 16 Mar 2026 15:18:38 -0400
Subject: [PATCH 05/10] feat: add /v1/models endpoint for OpenAI-compatible

---
 src/gateway/mod.rs | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/src/gateway/mod.rs b/src/gateway/mod.rs
index 53c4c537..73b09cd2 100644
--- a/src/gateway/mod.rs
+++ b/src/gateway/mod.rs
@@ -680,6 +680,7 @@ pub async fn run_gateway(host: &str, port: u16, config: Config) -> Result<()> {
         .route("/admin/paircode/new", post(handle_admin_paircode_new))
         // ── Existing routes ──
         .route("/health", get(handle_health))
+        .route("/v1/models", get(handle_models))
         .route("/metrics", get(handle_metrics))
         .route("/pair", post(handle_pair))
         .route("/webhook", post(handle_webhook))
@@ -921,6 +922,11 @@ pub struct WebhookBody {
     pub message: String,
 }
 
+async fn handle_models() -> impl axum::response::IntoResponse {
+    ([("content-type", "application/json")],
+     r#"{"object":"list","data":[{"id":"sid","object":"model"}]}"#)
+}
+
 /// POST /webhook — main webhook endpoint
 async fn handle_webhook(
     State(state): State<AppState>,
