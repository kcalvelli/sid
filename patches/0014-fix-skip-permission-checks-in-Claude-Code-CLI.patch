From: Keith Calvelli <keith@calvelli.dev>
Date: Wed, 18 Mar 2026 13:13:24 -0400
Subject: [PATCH 14/14] fix(providers): skip permission checks in Claude Code CLI
 Code CLI

---
 src/providers/claude_code.rs | 1 +
 1 file changed, 1 insertion(+)

diff --git a/src/providers/claude_code.rs b/src/providers/claude_code.rs
index bf1eea4..ad26bbd 100644
--- a/src/providers/claude_code.rs
+++ b/src/providers/claude_code.rs
@@ -116,6 +116,7 @@ impl ClaudeCodeProvider {
     async fn invoke_cli(&self, message: &str, model: &str) -> anyhow::Result<String> {
         let mut cmd = Command::new(&self.binary_path);
         cmd.arg("--print");
+        cmd.arg("--dangerously-skip-permissions");
 
         if Self::should_forward_model(model) {
             cmd.arg("--model").arg(model);
