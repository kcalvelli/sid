---
 src/providers/claude_code.rs | 19 +++++++------------
 1 file changed, 7 insertions(+), 12 deletions(-)

diff --git a/src/providers/claude_code.rs b/src/providers/claude_code.rs
index 784826e..4f1fe07 100644
--- a/src/providers/claude_code.rs
+++ b/src/providers/claude_code.rs
@@ -90,17 +90,12 @@ impl ClaudeCodeProvider {
             .any(|v| (temperature - v).abs() < TEMP_EPSILON)
     }
 
-    fn validate_temperature(temperature: f64) -> anyhow::Result<()> {
-        if !temperature.is_finite() {
-            anyhow::bail!("Claude Code provider received non-finite temperature value");
+    fn clamp_temperature(temperature: f64) -> f64 {
+        if !temperature.is_finite() || temperature < 0.85 {
+            0.7
+        } else {
+            1.0
         }
-        if !Self::supports_temperature(temperature) {
-            anyhow::bail!(
-                "temperature unsupported by Claude Code CLI: {temperature}. \
-                 Supported values: 0.7 or 1.0"
-            );
-        }
-        Ok(())
     }
 
     fn redact_stderr(stderr: &[u8]) -> String {
@@ -197,7 +192,7 @@ impl Provider for ClaudeCodeProvider {
         model: &str,
         temperature: f64,
     ) -> anyhow::Result<String> {
-        Self::validate_temperature(temperature)?;
+        let temperature = Self::clamp_temperature(temperature);
 
