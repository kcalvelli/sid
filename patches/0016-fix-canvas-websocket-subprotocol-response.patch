From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Keith Calvelli <keith@calvelli.dev>
Date: Mon, 24 Mar 2026 16:50:00 -0400
Subject: [PATCH] fix: echo Sec-WebSocket-Protocol in canvas WS upgrade

The canvas WebSocket handler reads the bearer token from the
Sec-WebSocket-Protocol header but doesn't echo a selected protocol
back in the 101 response. Per RFC 6455 section 4.2.2, if the client
sends protocol preferences the server must select one. Without this,
browsers reject the connection with "Sent non-empty
'Sec-WebSocket-Protocol' header but no response was received".

---
 src/gateway/canvas.rs | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/src/gateway/canvas.rs b/src/gateway/canvas.rs
index 75f50ff..aabbccd 100644
--- a/src/gateway/canvas.rs
+++ b/src/gateway/canvas.rs
@@ -195,7 +195,8 @@
         }
     }

-    ws.on_upgrade(move |socket| handle_canvas_socket(socket, state, id))
+    ws.protocols(["zeroclaw.v1"])
+        .on_upgrade(move |socket| handle_canvas_socket(socket, state, id))
         .into_response()
 }

