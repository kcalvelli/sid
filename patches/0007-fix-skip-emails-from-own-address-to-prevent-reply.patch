From: Keith Calvelli <keith@calvelli.dev>
Date: Mon, 16 Mar 2026 15:18:38 -0400
Subject: [PATCH 07/10] fix: skip emails from own address to prevent reply

---
 src/channels/email_channel.rs | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/src/channels/email_channel.rs b/src/channels/email_channel.rs
index 4e6f7c22..bac22b46 100644
--- a/src/channels/email_channel.rs
+++ b/src/channels/email_channel.rs
@@ -451,6 +451,12 @@ impl EmailChannel {
                 continue;
             }
 
+            // Skip emails from self (prevent reply loops)
+            if email.sender.eq_ignore_ascii_case(&self.config.from_address) {
+                info!("Ignoring email from self ({})", email.sender);
+                continue;
+            }
+
             let is_new = {
                 let mut seen = self.seen_messages.lock().await;
                 seen.insert(email.msg_id.clone())
