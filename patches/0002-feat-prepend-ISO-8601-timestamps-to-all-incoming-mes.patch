Subject: [PATCH 02/10] feat: prepend ISO-8601 timestamps to all incoming
 messages
 messages


diff --git a/src/channels/mod.rs b/src/channels/mod.rs
index 9a707e0..f15a879 100644
--- a/src/channels/mod.rs
+++ b/src/channels/mod.rs
@@ -14,6 +14,8 @@
 //! To add a new channel, implement [`Channel`] in a new submodule and wire it into
 //! [`start_channels`]. See `AGENTS.md` §7.2 for the full change playbook.
 
+use chrono::TimeZone;
+
 pub mod bluesky;
 pub mod clawdtalk;
 pub mod cli;
@@ -1973,7 +1975,11 @@ async fn process_channel_message(
         .is_some_and(|turns| !turns.is_empty());
 
     // Preserve user turn before the LLM call so interrupted requests keep context.
-    append_sender_turn(ctx.as_ref(), &history_key, ChatMessage::user(&msg.content));
+    let _ts = chrono::Local.timestamp_opt(msg.timestamp as i64, 0)
+        .single()
+        .unwrap_or_else(chrono::Local::now);
+    let _stamped_content = format!("[{}] {}", _ts.format("%Y-%m-%dT%H:%M:%S%:z"), msg.content);
+    append_sender_turn(ctx.as_ref(), &history_key, ChatMessage::user(&_stamped_content));
 
     // Build history from per-sender conversation cache.
     let prior_turns_raw = ctx
